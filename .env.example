# ─── SLACK ────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BLAKE_USER_ID=               # Blake's Slack User ID, e.g. U0123456789 (for FYI pings)
SLACK_RECRUITER_NOTIFY_CHANNEL=    # Channel or user ID to notify recruiters, e.g. #recruiting
SLACK_EXEC_APPROVAL_CHANNEL=       # Private channel where Paul/Alex approve offers

# ─── ASHBY ────────────────────────────────────────────────────
ASHBY_WEBHOOK_SECRET=              # Set in Ashby → Settings → Integrations → Webhooks

# ─── OPENAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key

# ─── GOOGLE APPS SCRIPT ───────────────────────────────────────
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-deployment-id/exec
APPS_SCRIPT_SECRET=your-random-secret-key

# ─── DOCUSIGN ─────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=          # Your DocuSign app integration key
DOCUSIGN_SECRET_KEY=               # OAuth secret
DOCUSIGN_ACCOUNT_ID=               # Your DocuSign account ID (GUID)
DOCUSIGN_BASE_PATH=https://na4.docusign.net/restapi   # Change to your server
DOCUSIGN_IMPERSONATED_USER_ID=     # User GUID to impersonate (JWT auth)
DOCUSIGN_PRIVATE_KEY=              # RSA private key (PEM string, newlines as \n)

# Signer 1 — Alex Bovee (signs first)
DOCUSIGN_ALEX_NAME=Alex Bovee
DOCUSIGN_ALEX_EMAIL=alex@yourcompany.com

# CC — Blake Haggerty (receives completed copy, does not sign)
DOCUSIGN_BLAKE_NAME=Blake Haggerty
DOCUSIGN_BLAKE_EMAIL=blake@yourcompany.com

# Webhook endpoint URL (this Lambda's URL, for DocuSign to call back)
DOCUSIGN_WEBHOOK_URL=https://your-api-gateway-url.amazonaws.com/prod/docusign-webhook

# ─── MISC ─────────────────────────────────────────────────────
OFFER_REMINDER_DAYS=3              # Days before auto-remind unsigned candidates
NODE_ENV=production

